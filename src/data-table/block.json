{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "awt/data-table",
	"carbonStyles": [
		"data-table",
		"data-table/sort"
	],
	"awt_component": "data-table",
	"title": "Data table",
	"category": "awt-data-display",
	"description": "A data table with sortable columns, a sticky header, and striped rows. Selectable and expandable rows, plus dynamic data sources, are available in AWT Premium.",
	"textdomain": "awt",
	"keywords": [
		"table",
		"data table",
		"carbon",
		"sortable"
	],
	"supports": {
		"html": false,
		"reusable": true,
		"className": true,
		"anchor": true
	},
	"attributes": {
		"headers": {
			"type": "array",
			"default": [
				{
					"key": "name",
					"text": "Name"
				},
				{
					"key": "type",
					"text": "Type"
				},
				{
					"key": "owner",
					"text": "Owner"
				}
			]
		},
		"rows": {
			"type": "array",
			"default": [
				{
					"name": "Load balancer",
					"type": "HTTP",
					"owner": "Maria S."
				},
				{
					"name": "Database",
					"type": "PostgreSQL",
					"owner": "Aisha K."
				},
				{
					"name": "Object storage",
					"type": "S3",
					"owner": "Diego R."
				}
			]
		},
		"size": {
			"type": "string",
			"default": "md"
		},
		"zebra": {
			"type": "boolean",
			"default": false
		},
		"useStaticWidth": {
			"type": "boolean",
			"default": false
		},
		"stickyHeader": {
			"type": "boolean",
			"default": false
		},
		"sortable": {
			"type": "boolean",
			"default": false
		},
		"defaultSortKey": {
			"type": "string",
			"default": ""
		},
		"defaultSortDirection": {
			"type": "string",
			"default": "asc"
		},
		"caption": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"viewScriptModule": "file:./view.js",
	"render": "file:./render.php",
	"style": "file:./style-index.css"
}
