{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "awt/skip-link",
	"carbonStyles": [],
	"awt_component": "skip-link",
	"title": "Skip link",
	"category": "awt-ui-shell",
	"description": "A \"skip to content\" link for keyboard users. It's the first thing they reach and appears when focused.",
	"textdomain": "awt",
	"keywords": [
		"skip",
		"accessibility",
		"a11y",
		"landmark",
		"bypass"
	],
	"supports": {
		"html": false,
		"reusable": false,
		"className": true,
		"anchor": false,
		"inserter": true
	},
	"attributes": {
		"targetId": {
			"type": "string",
			"default": "main-content"
		},
		"text": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
