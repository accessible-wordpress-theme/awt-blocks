{
	"extends": [
		"plugin:@wordpress/eslint-plugin/recommended"
	],
	"env": {
		"browser": true
	},
	"overrides": [
		{
			"files": [
				"**/*.test.js"
			],
			"env": {
				"jest": true
			}
		},
		{
			"files": [
				"scripts/**/*.js",
				"webpack.config.js"
			],
			"env": {
				"node": true
			},
			"rules": {
				"no-console": "off"
			}
		},
		{
			"files": [
				"tests/e2e/**/*.js",
				"playwright.config.js"
			],
			"extends": [
				"plugin:@wordpress/eslint-plugin/test-playwright"
			],
			"env": {
				"node": true
			}
		}
	]
}
